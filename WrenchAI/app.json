{
  "expo": {
    "name": "WrenchAI",
    "slug": "WrenchAI",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.senecajohns.wrenchai",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "WrenchAI uses Bluetooth to connect to your car's OBD-II diagnostic port.",
        "NSBluetoothPeripheralUsageDescription": "WrenchAI needs Bluetooth access to communicate with OBD-II devices.",
        "NSLocationWhenInUseUsageDescription": "Location is used to find nearby auto parts stores.",
        "UIBackgroundModes": [
          "bluetooth-central"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.senecajohns.wrenchai",
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": [
            "peripheral",
            "central"
          ],
          "bluetoothAlwaysPermission": "WrenchAI uses Bluetooth to connect to your car's OBD-II diagnostic port."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f159273a-79fc-4945-9ae0-76cc154f09e4"
      }
    },
    "owner": "seneca.r.johns"
  }
}
